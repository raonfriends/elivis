{
  "name": "@repo/api-server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env DOTENV_CONFIG_PATH=../../../.env tsx watch src/index.ts",
    "build": "tsc",
    "start": "cross-env DOTENV_CONFIG_PATH=../../../.env node dist/index.js",
    "lint": "node ../../../scripts/eslint-run.mjs . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "backfill:team-member-workspaces": "cross-env DOTENV_CONFIG_PATH=../../../.env tsx src/scripts/backfill-team-member-workspaces.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.0.0",
    "@repo/database": "workspace:*",
    "@repo/i18n": "workspace:*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "ldapts": "^8.1.7",
    "nodemailer": "^8.0.4",
    "openid-client": "^5.7.1",
    "pino": "^9.6.0",
    "sharp": "^0.34.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.3",
    "typescript": "^5.3.0"
  }
}

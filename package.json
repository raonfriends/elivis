{
  "name": "elivis",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "setup:mac": "bash scripts/setup-mac.sh",
    "setup:win": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-windows.ps1",
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter @repo/api-server dev",
    "dev:notification": "pnpm --filter @repo/notification-server dev",
    "dev:desktop": "pnpm --filter @repo/desktop dev",
    "build": "turbo build",
    "build:desktop": "turbo run build:desktop --filter=@repo/desktop",
    "prestart": "pnpm --filter @repo/i18n build",
    "start": "concurrently -k \"pnpm --filter web start\" \"pnpm --filter @repo/api-server start\" \"pnpm --filter @repo/notification-server start\"",
    "db:deploy": "pnpm --filter @repo/database db:deploy",
    "db:reset": "pnpm --filter @repo/database db:reset",
    "db:reset:force": "pnpm --filter @repo/database db:reset:force",
    "db:studio": "pnpm --filter @repo/database db:studio",
    "lint": "turbo lint",
    "test": "vitest run",
    "type-check": "turbo type-check",
    "docker:dev:up": "docker compose up -d",
    "docker:dev:down": "docker compose down",
    "docker:dev:logs": "docker compose logs -f",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "docker:prod:build": "docker compose -f docker-compose.prod.yml --env-file .env.production build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.3.0",
    "turbo": "^2.3.0",
    "vitest": "^3.2.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md,mdx,yaml,yml}": "prettier --write"
  },
  "packageManager": "pnpm@9.14.2",
  "pnpm": {
    "overrides": {
      "eslint": "^9.17.0",
      "zod-validation-error": "^5.0.0"
    }
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "dependencies": {
    "elivis": "link:"
  }
}

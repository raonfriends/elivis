# 루트에 `.env`로 복사하세요. `@repo/database`의 Prisma 스크립트가 이 파일을 읽습니다.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://elivis:elivis@localhost:5432/elivis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# 반드시 충분히 긴 무작위 문자열로 교체하세요 (예: openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# ── @repo/api-server ──────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# ── @repo/notification-server ─────────────────────────────────────────────────
NOTIFICATION_PORT=4001
NOTIFICATION_HOST=0.0.0.0

# 파일 저장 위치: "local" 또는 "s3"
UPLOAD_STORAGE=local
# 파일 업로드 최대 크기 (MB 단위), 기본값 50
UPLOAD_MAX_FILE_SIZE_MB=50
# 웹 클라이언트 사이드 검증용 (서버와 동일하게 유지)
NEXT_PUBLIC_UPLOAD_MAX_FILE_SIZE_MB=50

# ── S3 / 호환 오브젝트 스토리지 (UPLOAD_STORAGE=s3 일 때) ───────────────────
# UPLOAD_S3_BUCKET=my-bucket
# UPLOAD_S3_REGION=ap-northeast-2
# UPLOAD_S3_ACCESS_KEY=
# UPLOAD_S3_SECRET_KEY=
# UPLOAD_S3_ENDPOINT=          # 선택 — Cloudflare R2, MinIO 등 커스텀 엔드포인트
# UPLOAD_S3_CDN_URL=           # 선택 — CloudFront 등 CDN 퍼블릭 URL

# ── apps/web ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_NOTIFICATION_URL=http://localhost:4001

# ── Electron 정적 빌드 (데스크톱 번들용) ────────────────────────────────────────
# ELECTRON_STATIC=1

# 루트에 `.env`로 복사하세요. `@repo/database`의 Prisma 스크립트가 이 파일을 읽습니다.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://elivis:elivis@localhost:5432/elivis

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ───────────────────────────────────────────────────────────────────────
# 반드시 충분히 긴 무작위 문자열로 교체하세요 (예: openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# ── @repo/api-server ──────────────────────────────────────────────────────────
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000

# 공개 회원가입: DB(AuthSettings)가 없을 때만 첫 생성 시 초기값으로 사용. 이후는 관리자 › 보안 › 외부 회원가입에서 설정.
# PUBLIC_SIGNUP_ENABLED=true
# LDAP: AuthSettings 행이 처음 생성될 때만 아래 값이 DB 초기값으로 시드됩니다. 이후는 관리자 › 보안 › LDAP에서 설정합니다.
# LDAP_ENABLED=true
# LDAP_URL=ldap://localhost:389
# LDAP_USER_DN_TEMPLATE=
# LDAP_BIND_DN=
# LDAP_BIND_PASSWORD=
# LDAP_SEARCH_BASE=
# LDAP_SEARCH_FILTER=(mail={{email}})
# LDAP_NAME_ATTRIBUTE=cn

# Google Workspace OIDC: 모든 필수값이 유효하고 기존 SUPER_ADMIN 이 1명 이상 있을 때만 로그인 화면에 노출됩니다.
# fresh install 에서는 먼저 setup token 으로 첫 SUPER_ADMIN 을 생성해야 합니다.
# GOOGLE_OIDC_ENABLED=true
# GOOGLE_OIDC_CLIENT_ID=google-client-id.apps.googleusercontent.com
# GOOGLE_OIDC_CLIENT_SECRET=google-client-secret
# GOOGLE_OIDC_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
# GOOGLE_OIDC_ALLOWED_DOMAINS=example.com,team.example.com
# 현재 서버 기본 scope (고정): openid email profile
# GOOGLE_OIDC_SCOPES=openid email profile
# API 가 로그인 완료 후 되돌릴 웹 앱 기준 URL
# WEB_PUBLIC_URL=http://localhost:3000

# ── @repo/notification-server ─────────────────────────────────────────────────
NOTIFICATION_PORT=4001
NOTIFICATION_HOST=0.0.0.0

# 시스템 NDJSON 로그 루트 (API·알림 공통). 미설정 시 모노레포 루트 `.logs` 아래에 `YYYY-MM-DD/*.ndjson`
# (system, http-api, errors-api, notification, http-notification, errors-notification)
# SYSTEM_LOG_DIR=

# 파일 저장 위치: "local" 또는 "s3"
UPLOAD_STORAGE=local
# 파일 업로드 최대 크기 (MB 단위), 기본값 50
UPLOAD_MAX_FILE_SIZE_MB=50
# 웹 클라이언트 사이드 검증용 (서버와 동일하게 유지)
NEXT_PUBLIC_UPLOAD_MAX_FILE_SIZE_MB=50

# ── S3 / 호환 오브젝트 스토리지 (UPLOAD_STORAGE=s3 일 때) ───────────────────
# UPLOAD_S3_BUCKET=my-bucket
# UPLOAD_S3_REGION=ap-northeast-2
# UPLOAD_S3_ACCESS_KEY=
# UPLOAD_S3_SECRET_KEY=
# UPLOAD_S3_ENDPOINT=          # 선택 — Cloudflare R2, MinIO 등 커스텀 엔드포인트
# UPLOAD_S3_CDN_URL=           # 선택 — CloudFront 등 CDN 퍼블릭 URL

# ── apps/web ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_NOTIFICATION_URL=http://localhost:4001

# ── Electron 데스크톱 ─────────────────────────────────────────────────────────
# 배포 웹 URL은 apps/desktop/src/packagedWebUrl.ts 에서 수정 후 빌드
# 폐쇄망 등(시스템 환경 변수): 인터넷 검사 생략 — ELIVIS_DESKTOP_SKIP_INTERNET_CHECK=1

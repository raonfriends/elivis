generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

/// 시스템 전체 역할
enum SystemRole {
  SUPER_ADMIN /// 전체 관리자 — 모든 리소스 접근 가능
  USER        /// 일반 사용자 — 소속 프로젝트만 접근
}

/// 사용자 현재 상태
enum UserStatus {
  WORKING     /// 열일중
  VACATION    /// 휴가중
  OFF_WORK    /// 퇴근
  DEEP_FOCUS  /// 초집중모드
}

/// 프로젝트 내부 직책
enum ProjectRole {
  LEADER         /// 프로젝트장 — 멤버 관리·삭제·설정 변경
  DEPUTY_LEADER  /// 부프로젝트장 — 업무 관리·멤버 초대
  MEMBER         /// 일반 멤버 — 할당된 업무 조회·수정
}

/// 팀 내 역할
enum TeamRole {
  LEADER /// 팀 생성자·관리자
  MEMBER /// 일반 팀원
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model User {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id         String     @id
  email      String     @unique
  name       String?
  avatarUrl  String?    /// 프로필 이미지 경로 (e.g. /uploads/avatars/xxx.jpg)
  bio        String?    /// 프로필 메시지
  status     UserStatus @default(WORKING) /// 현재 상태
  password   String     /// bcrypt 해시 저장
  systemRole SystemRole @default(USER)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  memberships ProjectMember[]
  tasks       Task[]

  teamsCreated    Team[]       @relation("TeamCreator")
  teamMemberships TeamMember[]
}

model Project {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id          String   @id
  name        String
  description String?
  /// 소속 팀 (선택). 팀 상세에서 이 팀의 프로젝트로 집계됩니다.
  teamId      String?
  /// 프로젝트 일정 (선택)
  startDate   DateTime?
  endDate     DateTime?
  /// true면 종료일 미정(무기한)
  noEndDate   Boolean  @default(false)
  /// false면 팀/프로젝트 목록 등에서 비공개 처리(정책에 맞게 확장 가능)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team    Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  members ProjectMember[]
  tasks   Task[]
  /// 공용 팀프로젝트 등 — 여러 팀에 동시에 연결
  projectTeams ProjectTeam[]

  @@index([teamId])
}

/// 프로젝트 ↔ 팀 다대다 (한 프로젝트가 여러 팀에 노출)
model ProjectTeam {
  id        String   @id
  projectId String
  teamId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([projectId, teamId])
  @@index([teamId])
  @@index([projectId])
}

/// User ↔ Project 중개 테이블 (다대다 + 직책 포함)
model ProjectMember {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id        String      @id
  userId    String
  projectId String
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 한 유저는 한 프로젝트에 한 번만 소속
  @@unique([userId, projectId])
}

/// 팀 (워크스페이스 단위 그룹)
model Team {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id               String   @id
  name             String
  /// 목록·헤더에 쓰는 한 줄 짧은 설명 (플레인 텍스트)
  shortDescription String?
  /// 소개 탭 본문 (마크다운)
  introMessage     String?
  /// 팀 소개 상단 배너 이미지 경로 (e.g. /uploads/team-banners/xxx.webp)
  bannerUrl        String?
  /// 팀 목록용 배너 썸네일 이미지 경로 (e.g. /uploads/team-banners/xxx.thumb.webp)
  bannerThumbUrl   String?
  /// 소개 탭 블록 순서·너비 등 레이아웃 JSON (`IntroLayoutConfig`)
  introLayoutJson  String?
  /// true면 일반 목록에서 숨김(SUPER_ADMIN은 전체 목록에서 조회 가능). 팀원은 항상 자기 팀에 접근 가능.
  hiddenFromUsers  Boolean  @default(false)
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy User         @relation("TeamCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members   TeamMember[]
  projects  Project[]
  projectTeams ProjectTeam[]

  @@unique([name])
  @@index([createdAt(sort: Desc)])
  @@index([createdById])
}

model TeamMember {
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())
  /// 내 팀 목록 고정 순서 (작을수록 상단). null이면 고정 안 함.
  pinnedOrder Int?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([userId, pinnedOrder])
}

model Task {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id         String   @id
  title      String
  status     String   @default("todo")
  projectId  String
  assigneeId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

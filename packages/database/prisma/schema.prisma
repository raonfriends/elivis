generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

/// 시스템 전체 역할
enum SystemRole {
  SUPER_ADMIN /// 전체 관리자 — 모든 리소스 접근 가능
  USER        /// 일반 사용자 — 소속 프로젝트만 접근
}

/// 사용자 현재 상태
enum UserStatus {
  WORKING     /// 열일중
  VACATION    /// 휴가중
  OFF_WORK    /// 퇴근
  DEEP_FOCUS  /// 초집중모드
}

/// 프로젝트 내부 직책
enum ProjectRole {
  LEADER         /// 프로젝트장 — 멤버 관리·삭제·설정 변경
  DEPUTY_LEADER  /// 부프로젝트장 — 업무 관리·멤버 초대
  MEMBER         /// 일반 멤버 — 할당된 업무 조회·수정
}

/// 팀 내 역할
enum TeamRole {
  LEADER /// 팀 생성자·관리자
  MEMBER /// 일반 팀원
}

/// 워크스페이스 뷰 종류
enum WorkspaceViewType {
  LIST  /// 리스트(테이블) 뷰
  BOARD /// 보드(칸반) 뷰
}

/// 워크스페이스 업무 상태의 업무적 의미 (표시 이름과 별개로 집계·분석에 사용)
enum WorkspaceStatusSemantic {
  WAITING      /// 대기
  REVIEW       /// 검토중
  IN_PROGRESS  /// 진행중
  ON_HOLD      /// 보류
  DONE         /// 완료
}

/// 알림 종류
enum NotificationType {
  TASK_ASSIGNED          /// 업무 할당됨
  TASK_COMMENT           /// 업무에 댓글 달림
  TASK_DUE_SOON          /// 업무 마감 임박
  TASK_STATUS_CHANGED    /// 업무 상태 변경됨 (notifyOnChange)
  PROJECT_MEMBER_ADDED   /// 프로젝트에 멤버 추가됨
  TEAM_MEMBER_ADDED      /// 팀에 멤버 추가됨
  MENTION                /// 언급됨
  SYSTEM                 /// 시스템 알림
  TASK_REQUEST_RECEIVED  /// 업무 요청 받음
  TASK_REQUEST_ACCEPTED  /// 업무 요청 수락됨
  TASK_REQUEST_REJECTED  /// 업무 요청 거절됨
}

/// 업무 요청 상태
enum WorkspaceTaskRequestStatus {
  PENDING   /// 대기 중
  ACCEPTED  /// 수락됨
  REJECTED  /// 거절됨
}

/// 프로젝트 히스토리 행동 종류
enum ProjectHistoryAction {
  CREATED /// 생성됨
  UPDATED /// 수정됨
  DELETED /// 삭제됨
}

/// 프로젝트 히스토리 리소스 종류
enum ProjectHistoryResourceType {
  TASK             /// 워크스페이스 업무
  TASK_STATUS      /// 업무 상태 변경
  TASK_PRIORITY    /// 업무 우선순위 변경
  TASK_ASSIGNEE    /// 업무 담당자 변경
  TASK_DATE        /// 업무 날짜 변경
  TASK_DESCRIPTION /// 업무 설명 변경
  TASK_COMMENT     /// 업무 댓글
  TASK_ATTACHMENT  /// 업무 첨부파일
  WORKSPACE_STATUS   /// 워크스페이스 상태 태그
  WORKSPACE_PRIORITY /// 워크스페이스 우선순위 태그
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model User {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id         String     @id
  email      String     @unique
  name       String?
  avatarUrl  String?    /// 프로필 이미지 경로 (e.g. /uploads/avatars/xxx.jpg)
  bio        String?    /// 프로필 메시지
  status     UserStatus @default(WORKING) /// 현재 상태
  password   String     /// bcrypt 해시 저장
  systemRole SystemRole @default(USER)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  memberships ProjectMember[]
  tasks       Task[]

  teamsCreated    Team[]       @relation("TeamCreator")
  teamMemberships TeamMember[]
  teamFavorites    TeamFavorite[]
  projectFavorites ProjectFavorite[]
  workspaces          Workspace[]
  workspaceTasks      WorkspaceTask[]
  taskComments        WorkspaceTaskComment[]
  taskAttachments     WorkspaceTaskAttachment[]
  teamPosts           TeamPost[]
  teamPostComments    TeamPostComment[]
  taskNotes           WorkspaceTaskNote[]
  notifications       Notification[]
  projectHistories    ProjectHistory[]
  taskRequestsFrom    WorkspaceTaskRequest[] @relation("TaskRequestFrom")
  taskRequestsTo      WorkspaceTaskRequest[] @relation("TaskRequestTo")
}

model Project {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id          String   @id
  name        String
  description String?
  /// 소속 팀 (선택). 팀 상세에서 이 팀의 프로젝트로 집계됩니다.
  teamId      String?
  /// 프로젝트 일정 (선택)
  startDate   DateTime?
  endDate     DateTime?
  /// true면 종료일 미정(무기한)
  noEndDate   Boolean  @default(false)
  /// false면 팀/프로젝트 목록 등에서 비공개 처리(정책에 맞게 확장 가능)
  isPublic    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team    Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  members ProjectMember[]
  tasks   Task[]
  /// 공용 팀프로젝트 등 — 여러 팀에 동시에 연결
  projectTeams ProjectTeam[]
  workspaces   Workspace[]
  histories    ProjectHistory[]
  favorites    ProjectFavorite[]
  taskRequests WorkspaceTaskRequest[]

  @@index([teamId])
}

/// 프로젝트 즐겨찾기 (계정별 최대 10개)
model ProjectFavorite {
  id        String   @id
  userId    String
  projectId String
  /// 사이드바 표시 순서 (작을수록 상단)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId, order])
}

/// 프로젝트 ↔ 팀 다대다 (한 프로젝트가 여러 팀에 노출)
model ProjectTeam {
  id        String   @id
  projectId String
  teamId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  team    Team    @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([projectId, teamId])
  @@index([teamId])
  @@index([projectId])
}

/// User ↔ Project 중개 테이블 (다대다 + 직책 포함)
model ProjectMember {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id        String      @id
  userId    String
  projectId String
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 한 유저는 한 프로젝트에 한 번만 소속
  @@unique([userId, projectId])
}

/// 팀 (워크스페이스 단위 그룹)
model Team {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id               String   @id
  name             String
  /// 목록·헤더에 쓰는 한 줄 짧은 설명 (플레인 텍스트)
  shortDescription String?
  /// 소개 탭 본문 (마크다운)
  introMessage     String?
  /// 팀 소개 상단 배너 이미지 경로 (e.g. /uploads/team-banners/xxx.webp)
  bannerUrl        String?
  /// 팀 목록용 배너 썸네일 이미지 경로 (e.g. /uploads/team-banners/xxx.thumb.webp)
  bannerThumbUrl   String?
  /// 소개 탭 블록 순서·너비 등 레이아웃 JSON (`IntroLayoutConfig`)
  introLayoutJson  String?
  /// true면 일반 목록에서 숨김(SUPER_ADMIN은 전체 목록에서 조회 가능). 팀원은 항상 자기 팀에 접근 가능.
  hiddenFromUsers  Boolean  @default(false)
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  createdBy User         @relation("TeamCreator", fields: [createdById], references: [id], onDelete: Restrict)
  members   TeamMember[]
  favorites TeamFavorite[]
  projects  Project[]
  projectTeams ProjectTeam[]
  posts     TeamPost[]

  @@unique([name])
  @@index([createdAt(sort: Desc)])
  @@index([createdById])
}

/// 팀 즐겨찾기 (계정별 최대 10개)
model TeamFavorite {
  id        String   @id
  userId    String
  teamId    String
  /// 사이드바 표시 순서 (작을수록 상단)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId, order])
}

model TeamMember {
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())
  /// 내 팀 목록 고정 순서 (작을수록 상단). null이면 고정 안 함.
  pinnedOrder Int?

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([userId, pinnedOrder])
}

model Task {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id         String   @id
  title      String
  status     String   @default("todo")
  projectId  String
  assigneeId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
}

// ─────────────────────────────────────────────────────────────────────────────
// 워크스페이스 (프로젝트 × 사용자 개인 작업 공간)
// ─────────────────────────────────────────────────────────────────────────────

/// 프로젝트가 생성될 때 연결된 팀의 모든 팀원에게 1개씩 자동 생성되는 개인 작업 공간
model Workspace {
  /// 앱에서 `generateWorkspaceId()`로 발급 (ws-xxxxxxxx)
  id        String   @id
  projectId String
  userId    String
  /// 사이드바 등 UI에만 쓰는 표시 이름 (null·빈 값이면 프로젝트 이름 사용)
  sidebarLabel String? @db.VarChar(128)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       WorkspaceTask[]
  views       WorkspaceView[]
  statuses    WorkspaceStatus[]
  priorities  WorkspacePriority[]

  /// 프로젝트 내 사용자 1개
  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

/// 워크스페이스 내 개인 업무
model WorkspaceTask {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id          String    @id
  workspaceId String
  title       String
  /// 업무 상세 설명 (마크다운 허용)
  description String?
  /// WorkspaceStatus.id 를 저장 (워크스페이스별 커스텀 상태)
  statusId    String
  /// WorkspacePriority.id 를 저장 (선택 사항)
  priorityId  String?
  /// 같은 상태 내 정렬 순서 (작을수록 상단)
  order       Int       @default(0)
  /// 기본값은 워크스페이스 소유자, 다른 팀원에게 위임 가능
  assigneeId  String?
  startDate   DateTime?
  dueDate     DateTime?
  /// 상위 업무 ID — null이면 최상위 업무
  parentId    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workspace   Workspace               @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee    User?                   @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  parent      WorkspaceTask?          @relation("SubTasks", fields: [parentId], references: [id], onDelete: Cascade)
  subTasks    WorkspaceTask[]         @relation("SubTasks")
  comments    WorkspaceTaskComment[]
  attachments WorkspaceTaskAttachment[]
  notes       WorkspaceTaskNote[]

  @@index([workspaceId])
  @@index([assigneeId])
  @@index([parentId])
  @@index([workspaceId, statusId, order])
}

/// 업무 댓글
model WorkspaceTaskComment {
  id        String   @id
  taskId    String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task WorkspaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

/// 업무 노트 (리치 텍스트, 여러 개 작성 가능)
model WorkspaceTaskNote {
  id        String   @id
  taskId    String
  userId    String
  /// Tiptap HTML 형식
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task WorkspaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

/// 업무 첨부 파일
model WorkspaceTaskAttachment {
  id        String   @id
  taskId    String
  userId    String
  fileName  String
  fileSize  Int
  mimeType  String
  fileUrl   String
  createdAt DateTime @default(now())

  task WorkspaceTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

/// 워크스페이스별 커스텀 우선순위 (Notion 스타일)
model WorkspacePriority {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id          String   @id
  workspaceId String
  name        String
  /// 색상 키: gray | red | orange | yellow | green | blue | purple | pink
  color       String   @default("gray")
  /// 목록 표시 순서 (작을수록 상단)
  order       Int      @default(0)
  /// 우선순위 가중치 (높을수록 먼저 처리. 0 = 미설정, 1~100 범위 권장)
  value       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

/// 워크스페이스별 커스텀 업무 상태 (Notion 스타일)
model WorkspaceStatus {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id          String   @id
  workspaceId String
  name        String
  /// 색상 키: gray | red | orange | yellow | green | blue | purple | pink
  color       String   @default("gray")
  /// 목록 표시 순서 (작을수록 상단)
  order       Int      @default(0)
  /// true면 업무가 이 상태로 변경될 때 프로젝트 팀원 전체에게 알림 발송
  notifyOnChange Boolean @default(false)
  /// 표시 이름과 무관한 상태 의미 (대기·검토·진행·보류·완료) — 집계에 사용
  semantic    WorkspaceStatusSemantic @default(IN_PROGRESS)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// 워크스페이스 내 상태 이름은 유일
  @@unique([workspaceId, name])
  @@index([workspaceId])
}

/// 리스트/보드 뷰 설정 저장 — 워크스페이스당 각 타입 1개
model WorkspaceView {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id          String            @id
  workspaceId String
  type        WorkspaceViewType
  name        String
  /// 열 너비·정렬 등 뷰별 추가 설정 JSON
  configJson  String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  /// 워크스페이스당 뷰 타입은 1개
  @@unique([workspaceId, type])
  @@index([workspaceId])
}

// ─────────────────────────────────────────────────────────────────────────────
// 프로젝트 변경 히스토리
// ─────────────────────────────────────────────────────────────────────────────

/// 프로젝트 내 모든 변경 사항을 기록하는 감사 로그
model ProjectHistory {
  /// 앱에서 `generatePublicId()`로 발급 (12자 영숫자)
  id           String                     @id
  projectId    String
  /// 변경을 수행한 사용자
  userId       String
  action       ProjectHistoryAction
  resourceType ProjectHistoryResourceType
  /// 변경된 리소스 ID (taskId, statusId 등)
  resourceId   String?
  /// 변경된 리소스 이름 (삭제 후에도 표시용)
  resourceName String?
  /// 변경 전 값 (JSON)
  before       String?
  /// 변경 후 값 (JSON)
  after        String?
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectId, createdAt(sort: Desc)])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────────────────────
// 알림
// ─────────────────────────────────────────────────────────────────────────────

/// 사용자별 알림
model Notification {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id        String           @id
  /// 수신 대상 유저
  userId    String
  type      NotificationType
  title     String
  message   String?
  /// 연관 리소스 JSON (예: { "taskId": "abc", "workspaceId": "ws-xyz" })
  data      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
}

// ─────────────────────────────────────────────────────────────────────────────
// 업무 요청
// ─────────────────────────────────────────────────────────────────────────────

/// 팀원이 다른 팀원에게 업무를 요청할 때 사용
model WorkspaceTaskRequest {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id           String                     @id
  projectId    String
  fromUserId   String
  toUserId     String
  title     String
  content   String?
  /// 긴급 요청 여부
  isUrgent  Boolean                    @default(false)
  status    WorkspaceTaskRequestStatus @default(PENDING)
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromUser User    @relation("TaskRequestFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("TaskRequestTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([fromUserId])
  @@index([toUserId])
  @@index([toUserId, status])
}

// ─────────────────────────────────────────────────────────────────────────────
// 팀 커뮤니티
// ─────────────────────────────────────────────────────────────────────────────

/// 팀 커뮤니티 게시글
model TeamPost {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id        String   @id
  teamId    String
  authorId  String
  /// 카테고리: general | notice | discussion | share
  category  String   @default("general")
  title     String
  /// 마크다운 허용
  content   String
  /// true면 목록 상단 고정 (팀장만 설정 가능)
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  team        Team                  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  author      User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    TeamPostComment[]
  attachments TeamPostAttachment[]

  @@index([teamId])
  @@index([authorId])
  @@index([teamId, isPinned, createdAt(sort: Desc)])
}

/// 팀 커뮤니티 게시글 첨부파일
model TeamPostAttachment {
  id        String   @id
  postId    String
  /// 파일 원본명
  name      String
  /// 공개 URL (로컬: /uploads/..., S3: https://...)
  url       String
  mimeType  String
  /// 파일 크기 (bytes)
  size      Int
  createdAt DateTime @default(now())

  post TeamPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

/// 팀 커뮤니티 게시글 댓글
model TeamPostComment {
  /// 앱에서 `generatePublicId()`로 발급 (8자 영숫자)
  id        String   @id
  postId    String
  authorId  String
  /// null이면 최상위 댓글, non-null이면 해당 댓글의 답글
  parentId  String?
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  post    TeamPost         @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  TeamPostComment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies TeamPostComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

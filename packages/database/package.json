{
  "name": "@repo/database",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "postinstall": "node ./scripts/prisma-generate-retry.mjs",
    "build": "node ./scripts/prisma-generate-retry.mjs && tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --max-warnings 0",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:setup": "dotenv -e ../../.env -- prisma generate && dotenv -e ../../.env -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env -- prisma migrate deploy && prisma generate",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "db:reset:force": "dotenv -e ../../.env -- prisma migrate reset --force",
    "db:resolve": "dotenv -e ../../.env -- prisma migrate resolve",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "dev:web": "pnpm -w run dev:web",
    "dev:server": "pnpm -w run dev:server",
    "dev:notification": "pnpm -w run dev:notification",
    "dev:desktop": "pnpm -w run dev:desktop",
    "dev:all": "pnpm -w run dev"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "dotenv-cli": "^8.0.0",
    "eslint-config-prettier": "^9.1.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.3.0"
  }
}
